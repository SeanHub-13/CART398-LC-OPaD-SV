osc(5, 0.1)
.color(0.5, 0, 0.1)
.modulate(noise(6).colorama(0.1), 0.9)
.add(src(o0).scale(1.015).rotate(0.002), () => 0.5 + Math.sin(time) * 0.3)
.out()