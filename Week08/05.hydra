osc(180, 0.015)
.rotate(1.5)
.modulate(osc(6, 0.02), 0.2)
.modulateScale(noise(2, 0.1)
.scrollX(() => time * 0.05), 0.2)
.add(src(o0).scale(1.01).brightness(0.02), 0.2)
.contrast(1.1)
.brightness(-0.3)
.color(0.2, 0.4, 1.0)
.modulate(noise(2).scale(2), 0.3)
.out()