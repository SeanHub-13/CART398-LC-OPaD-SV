voronoi(10, 0.3, 0.2)
.brightness(-0.5)
.contrast(1.2)
.color(0.2, 0.3, 0.9)
.scrollY(() => time * 0.1)
.add(osc(80, 0.02, 1)
.color(1, 1, 1, 0.1)
.modulate(noise(2), 0.2), 0.025)
.modulate(noise(3).scale(1.5, 1, 1), 0.4)
.out()