gradient(0.6)
.colorama(0.8)
.modulateScale(
voronoi(() => 8 + Math.sin(time*0.4)*4, 0.5, 2), 0.4)
.kaleid(() => 5 + Math.floor(Math.sin(time*0.1)))
.pixelate(300, 300)
.contrast(1.5)
.saturate(2)
.out()