voronoi(10, 0.8, 2)
.color(0,1,0.5)
.colorama(0.0001)
.mult(
osc(30, -0.4, 0.5)
.rotate(1.5,0),0.3)
.rotate(() => Math.sin(time*0.05)*0.2)
.scale(() => 1 + Math.sin(time*0.07)*0.05)
.modulate(
noise(2,0.1)
.brightness(-0.2),0.15)
.out()